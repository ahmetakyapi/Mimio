# Neon PostgreSQL bağlantı dizesi
# Vercel'de Neon entegrasyonunu aktifleştirirseniz bu değişken otomatik eklenir.
# Lokal geliştirme için .env.local dosyasına kopyalayıp gerçek değeri yazın.
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Uygulama URL'si (sitemap, robots ve OG image için)
NEXT_PUBLIC_APP_URL="https://mimio.app"
